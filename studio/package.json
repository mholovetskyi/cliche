{
  "name": "cliche-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Cliche Studio — the local web app front-end. Built with Vite + React + Tailwind; the build output is embedded into the Go binary (internal/web/static).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
