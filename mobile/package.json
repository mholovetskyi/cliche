{
  "name": "cliche-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Cliché Studio — the iOS/Android app. Wraps the Studio web UI with Capacitor, pointed at a remote Cliché backend (the cloud gateway / a networked `cliche serve`).",
  "scripts": {
    "build:web": "npm --prefix ../studio run build",
    "sync": "npm run build:web && cap sync",
    "ios": "cap open ios",
    "android": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/local-notifications": "^6.1.0",
    "@capacitor/preferences": "^6.0.3",
    "@capacitor/push-notifications": "^6.0.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2"
  }
}
